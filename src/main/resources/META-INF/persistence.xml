<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.1"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd">

    <persistence-unit name="ins" transaction-type="JTA">
        <jta-data-source>java:/ins</jta-data-source>
        <class>dao.entities.Application</class>
        <class>dao.entities.Department</class>
        <class>dao.entities.Menu</class>
        <class>dao.entities.Notification</class>
        <class>dao.entities.NotificationType</class>
        <class>dao.entities.Role</class>
        <class>dao.entities.RoleMenu</class>
        <class>dao.entities.Status</class>
        <class>dao.entities.Submenu</class>
        <class>dao.entities.TaskConfig</class>
        <class>dao.entities.Token</class>
        <class>dao.entities.UserAttempts</class>
        <class>dao.entities.UserDetails</class>
        <class>dao.entities.Users</class>
        <class>dao.entities.WebserviceRequest</class>
        <class>dao.entities.PolicyHolder</class>
        <class>dao.entities.BaseAmount</class>
        <class>dao.entities.Beneficiaries</class>
        <class>dao.entities.Coverage</class>
        <class>dao.entities.CoverageType</class>
        <class>dao.entities.Currency</class>
        <class>dao.entities.IDType</class>
        <class>dao.entities.MemberProductPrice</class>
        <class>dao.entities.PaymentLog</class>
        <class>dao.entities.PaymentSchedule</class>
        <class>dao.entities.InsurancePolicy</class>
        <class>dao.entities.ProcessAction</class>
        <class>dao.entities.ProcessState</class>
        <class>dao.entities.ProcessWorkflow</class>
        <class>dao.entities.Product</class>
        <class>dao.entities.ProductConfig</class>
        <class>dao.entities.RelationShip</class>
        <class>dao.entities.Frequency</class>
        <class>dao.entities.SubProduct</class>
        <class>dao.entities.DocumentFile</class>
        <class>dao.entities.DocumentType</class>
        <class>dao.entities.CoreErrorMapping</class>
        <class>dao.entities.InsuranceCompany</class>
        <class>dao.entities.CoverageTypeRate</class>
        <class>dao.entities.FileTransferLog</class>
        <class>dao.entities.InsurancePolicyHistory</class>
        <class>dao.entities.Term</class>
        <class>dao.entities.CountryMap</class>
        <class>dao.entities.ContractType</class>
        <class>dao.entities.CommissionMap</class>
        <class>dao.entities.CollectionLog</class>
        <class>dao.entities.ReportFieldMap</class>
        <class>dao.entities.Industry</class>
        <class>dao.entities.JobTitle</class>
        <class>dao.entities.SubProductCurrency</class>
        <class>dao.entities.PolicySyncHistory</class>
        <class>dao.entities.SoundDetail</class>
        <class>dao.entities.CoverageOption</class>
        <class>dao.entities.ErrorLog</class>
        <class>dao.entities.BenefitMap</class>
        <class>dao.entities.BenefitCycle</class>
        <class>dao.entities.InsuranceOutstandingAmount</class>
        <class>dao.entities.InsuranceStatementEntry</class>
        <class>dao.entities.InsuranceBalance</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="hibernate.generate_statistics" value="false"/>
            <property name="hibernate.c3p0.min_size" value="5"/>
            <property name="hibernate.c3p0.max_size" value="100"/>
            <property name="hibernate.c3p0.timeout" value="1500"/>
            <property name="hibernate.c3p0.max_statements" value="50"/>
            <property name="hibernate.c3p0.idle_test_period" value="3000"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.use_sql_comments" value="false"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.connection.autocommit" value="false" />
        </properties>

    </persistence-unit>

</persistence>